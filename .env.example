# ZA Support Health Check Backend v11.1
# Copy to .env and fill in values

# PostgreSQL connection string (Render auto-populates via render.yaml)
DATABASE_URL=postgresql://user:password@host:5432/zasupportdb

# API key for agent authentication (generate a strong key for production)
API_KEY=change-me-to-a-strong-random-key

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me

# Server
PORT=8080
DEBUG=false

# CORS origins (comma-separated)
ALLOWED_ORIGINS=https://zasupport.com,https://app.zasupport.com,http://localhost:3000

# Alert thresholds (defaults shown)
CPU_CRITICAL=90
CPU_WARNING=75
MEMORY_CRITICAL=90
MEMORY_WARNING=80
DISK_CRITICAL=90
DISK_WARNING=80
BATTERY_CRITICAL=20
THREAT_CRITICAL=7

# Agent Auth
AGENT_AUTH_TOKEN=change-me-to-strong-random-token
AGENT_AUTH_TOKEN_OLD=

# ISP Outage Monitor
ISP_MONITOR_ENABLED=false
ISP_MONITOR_STATUS_PAGE_CHECK_INTERVAL=300
ISP_MONITOR_AGENT_HEARTBEAT_TIMEOUT=180
ISP_MONITOR_OUTAGE_CONFIRMATION_THRESHOLD=3
ISP_MONITOR_OUTAGE_DEGRADED_THRESHOLD=10.0
ISP_MONITOR_ALERT_COOLDOWN_MINS=30
REDIS_URL=redis://localhost:6379/0

# Formbricks Webhooks (copy secret from Formbricks dashboard after creating form)
FORMBRICKS_WEBHOOK_SECRET=

# Breach Scanner (optional — set to enable threat intel lookups)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
HIBP_API_KEY=

# Networking Integrations (optional)
CLOUDFLARE_RADAR_TOKEN=
RIPE_ATLAS_API_KEY=
NETWORKING_INTEGRATIONS_ENABLED=false
